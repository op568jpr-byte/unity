{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "unity-beta-azure.vercel.app"
        }
      ],
      "destination": "https://unityhosteljaipur.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/health",
      "destination": "data:application/json,{\"status\":\"ok\",\"mode\":\"vercel\"}"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
